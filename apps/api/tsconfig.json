{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "commonjs",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@techia/*": ["../../packages/*/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
