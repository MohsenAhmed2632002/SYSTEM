{
  "extends": "../../packages/tsconfig/base.json",

  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "emitDeclarationOnly": true,

    "outDir": "dist",

    "rootDir": "src",

    "composite": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}